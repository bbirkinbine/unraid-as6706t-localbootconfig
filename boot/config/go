#!/bin/bash
# Start the Management Utility
/usr/local/sbin/emhttp

# --- Fan autocontrol daemon (Asustor Lockerstor 6 Gen2) ---
install -m 755 /boot/config/scripts/fan-autocontrol.sh /usr/local/sbin/fan-autocontrol.sh
/usr/local/sbin/fan-autocontrol.sh start

# --- Front-panel green status LED (gpled1 / GP47): disable its hardware blink ---
# The disk-activity daemon (started below) drives this LED (NVMe activity by default, or forced
# off/solid via STATUS_LED) and re-asserts blink=0 itself; this pre-seed just keeps it from
# blinking before the daemon grabs it.
for f in /sys/devices/platform/asustor_it87.*/hwmon/hwmon*/gpled1_blink; do
  [ -w "$f" ] && echo 0 > "$f"
done

# --- Front-panel LCD: live IP + CPU temp + fan RPM ---
install -m 755 /boot/config/scripts/asustor-lcd.sh /usr/local/sbin/asustor-lcd.sh
install -m 755 /boot/config/scripts/lcd-info.sh    /usr/local/sbin/lcd-info.sh
/usr/local/sbin/lcd-info.sh start

# --- Per-bay disk-activity LEDs (green front-bay LEDs, via GPIO chardev) ---
# Unraid's kernel lacks CONFIG_LEDS_GPIO + the disk-activity trigger, so these are driven
# directly from /proc/diskstats by a small Perl daemon. See docs/disk-leds.md.
install -m 755 /boot/config/scripts/disk-led.pl /usr/local/sbin/disk-led.pl
install -m 755 /boot/config/scripts/disk-led.sh /usr/local/sbin/disk-led.sh
/usr/local/sbin/disk-led.sh start

# --- Persist Claude Code CLI across reboots (RAM root) — DISABLED on boot ---
# Intentionally not run automatically so it can't interfere with normal boot.
# To re-establish Claude after a reboot, run by hand:
#   /boot/config/scripts/claude-persist.sh
# (or: install -m 755 /boot/config/scripts/claude-persist.sh /usr/local/sbin/claude-persist.sh && /usr/local/sbin/claude-persist.sh)
#install -m 755 /boot/config/scripts/claude-persist.sh /usr/local/sbin/claude-persist.sh
#/usr/local/sbin/claude-persist.sh
